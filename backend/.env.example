# ============================================
# NPAxis Environment Variables Configuration
# ============================================
# TEMPLATE FILE - DO NOT MODIFY UNLESS ADDING NEW VARIABLES
#
# SETUP INSTRUCTIONS:
# 1. For development: Load into IDE run configuration or terminal
# 2. For production: Use CI/CD pipeline or Secrets Manager
# 3. NEVER commit actual secrets to version control
#
# ============================================
# Configuration Structure
# ============================================
# This application uses Spring Profiles with environment-specific configs:
#
# 1. application.yml           → Universal base config
# 2. application-dev.yml       → Development (has fallback defaults)
# 3. application-staging.yml   → Staging (production-like)
# 4. application-prod.yml      → Production (requires all env vars)
#
# Active profile is set via: SPRING_PROFILES_ACTIVE
# All environment variables below override YAML defaults
#
# ============================================
# Spring Profile Selection
# ============================================
SPRING_PROFILES_ACTIVE=dev

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_URL=jdbc:postgresql://localhost:5432/npaxis
DB_USERNAME=postgres
DB_PASSWORD=root
DB_DRIVER=org.postgresql.Driver

# ============================================
# JWT Security Configuration
# ============================================
# CRITICAL: In production, generate with: openssl rand -hex 64
# Must be at least 64 characters, randomly generated
JWT_SECRET=dev-secret-key-please-change-in-production
JWT_EXPIRATION_ACCESS=900000
JWT_EXPIRATION_REFRESH=604800000

# ============================================
# Email Configuration (SMTP)
# ============================================
# Supported providers:
# - Gmail: smtp.gmail.com:587 (use App Passwords)
# - SendGrid: smtp.sendgrid.net:587 (username=apikey)
# - AWS SES: email-smtp.region.amazonaws.com:587
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
EMAIL_FROM_ADDRESS=noreply@npaxis.com
EMAIL_FROM_NAME=NPaxis Platform

# ============================================
# Stripe Payment Configuration
# ============================================
# Dashboard: https://dashboard.stripe.com/apikeys
# Test keys start with: sk_test_, pk_test_
# Live keys start with: sk_live_, pk_live_
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_API_VERSION=2024-12-18.acacia
STRIPE_MAX_NETWORK_RETRIES=3
STRIPE_CONNECT_TIMEOUT_MS=5000
STRIPE_READ_TIMEOUT_MS=10000
STRIPE_CURRENCY=usd
STRIPE_TRIAL_DAYS=14

# Stripe Redirect URLs (must match your frontend URL exactly)
# Shown to customers after payment processing
STRIPE_SUCCESS_URL=http://localhost:5173/subscription/success
STRIPE_CANCEL_URL=http://localhost:5173/subscription/cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:5173/dashboard

# ============================================
# CORS Configuration
# ============================================
# Comma-separated frontend origins allowed to call this API
# Dev: http://localhost:3000,http://localhost:5173,http://localhost:5174
# Prod: https://npaxis.com,https://www.npaxis.com
NPAXIS_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# ============================================
# DigitalOcean Spaces Configuration
# ============================================
# S3-compatible object storage for files/documents
# Setup: https://cloud.digitalocean.com/spaces
# Regions: nyc3, sfo3, sgp1
DO_SPACES_BUCKET=npaxis-files
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_CDN_ENDPOINT=https://npaxis.nyc3.cdn.digitaloceanspaces.com
DO_SPACES_ACCESS_KEY=your-do-access-key
DO_SPACES_SECRET_KEY=your-do-secret-key

# ============================================
# AWS S3 Configuration (Alternative/Backup)
# ============================================
CLOUD_BUCKET_NAME=npaxis-files
CLOUD_REGION=us-east-1
CLOUD_ACCESS_KEY=your-aws-access-key
CLOUD_SECRET_KEY=your-aws-secret-key

# ============================================
# Local Storage Configuration
# ============================================
STORAGE_LOCAL_DIRECTORY=uploads
STORAGE_ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,doc,docx

# ============================================
# Application Settings
# ============================================
APP_NAME=NPAxis
APP_PROFILE=dev
PORT=8080
LOG_FILE_PATH=./logs
