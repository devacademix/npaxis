# ============================================
# NPaxis Application Secrets Configuration
# TEMPLATE FILE - DO NOT USE DIRECTLY
# ============================================
# INSTRUCTIONS:
# 1. Copy this file to .env.secrets and fill in your values
# 2. NEVER commit .env.secrets to version control
# 3. This template file (.env.example) is safe to commit
#
# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_URL=jdbc:postgresql://localhost:5432/npaxis
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_DRIVER=org.postgresql.Driver

# ============================================
# EMAIL CONFIGURATION (SMTP)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
EMAIL_FROM_ADDRESS=noreply@npaxis.com
EMAIL_FROM_NAME=NPaxis Platform

# ============================================
# JWT SECURITY CONFIGURATION
# ============================================
# Generate a strong secret key using: openssl rand -hex 64
JWT_SECRET=your-very-long-secret-key-here-change-in-production
JWT_EXPIRATION_ACCESS=900000
JWT_EXPIRATION_REFRESH=604800000

# ============================================
# STRIPE PAYMENT CONFIGURATION
# ============================================
# Get from https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_API_VERSION=2024-12-18.acacia
STRIPE_MAX_NETWORK_RETRIES=3
STRIPE_CONNECT_TIMEOUT_MS=5000
STRIPE_READ_TIMEOUT_MS=10000
STRIPE_CURRENCY=usd
STRIPE_TRIAL_DAYS=14

STRIPE_SUCCESS_URL=http://localhost:5173/subscription/success
STRIPE_CANCEL_URL=http://localhost:5173/subscription/cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:5173/dashboard

# ============================================
# STORAGE CONFIGURATION
# ============================================
STORAGE_LOCAL_DIRECTORY=uploads
STORAGE_ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg

# ============================================
# CLOUD STORAGE CONFIGURATION
# ============================================
CLOUD_BUCKET_NAME=npaxis-files
CLOUD_REGION=us-east-1
CLOUD_ACCESS_KEY=your-cloud-access-key
CLOUD_SECRET_KEY=your-cloud-secret-key

# ============================================
# APPLICATION SPECIFIC CONFIGURATION
# ============================================
APP_NAME=NPAxis
APP_PROFILE=dev

